# --- Required ---

# NEAR AI Cloud (verifiable-inference LLM provider used for screening).
NEAR_AI_CLOUD_API_KEY=your_near_ai_cloud_api_key_here

# PostgreSQL connection string used by Drizzle for the screening_results table.
# On Railway app service, reference the Postgres service with:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://username:password@localhost:5432/ngov_db

# --- Optional / recommended ---

# Plausible analytics domain for the deployed site (e.g., neargov.ai).
# Analytics are disabled outside production regardless of this value.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=neargov.ai

# WalletConnect project ID. Only needed if you want WalletConnect-based wallets
# (HOT, etc.) to work in addition to NEAR-native wallets. Get one at
# https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public site URL, used as the canonical base for verifiable-inference proof
# URLs. Optional on Railway unless you want to force a custom domain; the app
# falls back to RAILWAY_PUBLIC_DOMAIN.
NEXT_PUBLIC_SITE_URL=https://your-deployment.example.com

# --- TEE attestation (optional, for Intel TDX verifiable inference) ---

# Endpoint of the Intel TDX attestation verifier service. If unset, attestation
# verification is skipped client-side.
INTEL_TDX_ATTESTATION_URL=
# API key for the Intel TDX verifier endpoint above.
INTEL_TDX_API_KEY=

# --- Development / testing ---

# When "true", verification endpoints return canned mock responses instead of
# calling Intel / NRAS. Useful for local development and CI.
VERIFY_USE_MOCKS=false
